# Release signing (upload-key) для подписанного AAB — ОБРАЗЕЦ формата.
#
# 1. Скопируй этот файл в keystore.properties (тот же репо-корень) — он gitignored.
# 2. Сгенерируй upload-keystore (пароли выбираешь САМ и хранишь вечно; потеря = сброс
#    через поддержку Google при Play App Signing). JBR keytool на этой машине:
#      & "C:\Program Files\Android\Android Studio\jbr\bin\keytool.exe" `
#         -genkeypair -v -keystore planeflow-upload.keystore -alias upload `
#         -keyalg RSA -keysize 2048 -validity 10000
# 3. Заполни поля ниже. storeFile лучше абсолютным путём (относительный резолвится от android/app).
# 4. npm run build:www && npx cap add android && npm run setup:android && npx cap sync android
#    затем в android/:  gradlew bundleRelease   → app/build/outputs/bundle/release/app-release.aab
#
# setup:android скопирует этот файл в android/, а app/build.gradle подтянет его при release-сборке.
# Без keystore.properties release-сборка остаётся НЕподписанной (debug и CI не затронуты).

storeFile=C:/Users/you/keys/planeflow-upload.keystore
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
